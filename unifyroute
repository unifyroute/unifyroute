"""
unifyroute — UnifyRoute command-line interface

Usage:
  unifyroute setup                    Interactive first-time setup
  unifyroute wizard                   Interactive provider/routing/brain setup wizard
  unifyroute refresh                  Re-sync deps, rebuild GUI, run migrations
  unifyroute uninstall                Stop services and clean up
  unifyroute start                    Start the UnifyRoute application
  unifyroute stop                     Stop the running application
  unifyroute restart                  Stop and start the application
  unifyroute get token [all|admin|api]  List tokens (requires master password)
  unifyroute create token [admin|api]   Create a token (requires master password)
  unifyroute update token <id> <label>  Update token label (requires master password)
  unifyroute import-keys <file.json>  Bulk import provider API keys
  unifyroute help                     Show this help
"""
import getpass
import os
import subprocess
import sys
from pathlib import Path
import base64

# Force UTF-8 encoding for output
if sys.platform == "win32":
    import io
    sys.stdout = io.TextIOWrapper(sys.stdout.buffer, encoding='utf-8')
    sys.stderr = io.TextIOWrapper(sys.stderr.buffer, encoding='utf-8')

SCRIPT_DIR = Path(__file__).parent.resolve()
UV = None  # resolved lazily


def _find_uv() -> list[str]:
    global UV
    if UV:
        return UV
    import shutil

    # First check venv
    venv_dir = SCRIPT_DIR / ".venv"
    if sys.platform == "win32":
        venv_uv = venv_dir / "Scripts" / "uv.exe"
    else:
        venv_uv = venv_dir / "bin" / "uv"

    if venv_uv.exists():
        uv = [str(venv_uv)]
    else:
        uv_path = shutil.which("uv")
        if uv_path:
            uv = [uv_path]
        else:
            uv = None

    # Try as a python module
    if not uv:
        try:
            result = subprocess.run([sys.executable, "-m", "uv", "--version"], capture_output=True, timeout=5)
            if result.returncode == 0:
                uv = [sys.executable, "-m", "uv"]
        except Exception:
            pass

    if not uv:
        uv_name = "uv.exe" if sys.platform == "win32" else "uv"
        home_uv = Path.home() / ".local" / "bin" / uv_name
        if home_uv.exists():
            uv = [str(home_uv)]

    if not uv:
        _die("'uv' not found. Install: curl -LsSf https://astral.sh/uv/install.sh | sh")
    UV = uv
    return UV


def _load_env():
    """Source the .env file into os.environ."""
    env_file = SCRIPT_DIR / ".env"
    if env_file.exists():
        for line in env_file.read_text().splitlines():
            stripped = line.strip()
            if not stripped or stripped.startswith("#"):
                continue
            if "=" in stripped:
                key, _, val = stripped.partition("=")
                os.environ.setdefault(key.strip(), val.strip())


def _die(msg: str, code: int = 1):
    print(f"❌  {msg}", file=sys.stderr)
    sys.exit(code)


def _ok(msg: str):
    print(f"✅  {msg}")


def _info(msg: str):
    print(f"ℹ️   {msg}")


def _unwrap_password(wrapped: str) -> str:
    """Decrypt a password if it's in the 'enc:iv:ct' format."""
    if not wrapped.startswith("enc:"):
        return wrapped
    
    # Needs cryptography. If not present, we can't unwrap.
    try:
        from cryptography.hazmat.primitives.ciphers.aead import AESGCM
    except ImportError:
        # If we can't import it, just return it as is and wait for verification to fail
        # or maybe warn the user.
        return wrapped

    try:
        parts = wrapped.split(":")
        if len(parts) != 3:
            return wrapped
        
        iv = base64.urlsafe_b64decode(parts[1])
        ciphertext = base64.urlsafe_b64decode(parts[2])
        
        # Get VAULT_MASTER_KEY
        val = os.environ.get("VAULT_MASTER_KEY")
        if not val:
            return wrapped
        
        key_bytes = base64.urlsafe_b64decode(val)
        aesgcm = AESGCM(key_bytes)
        plaintext = aesgcm.decrypt(iv, ciphertext, None)
        return plaintext.decode('utf-8')
    except Exception:
        return wrapped


def _verify_master_password() -> bool:
    """
    Ask the user for the master password and validate it against MASTER_PASSWORD
    (or ADMIN_PASSWORD for backward compatibility) from the environment.
    Returns True if verified, exits on failure.
    """
    expected = _unwrap_password(os.environ.get("MASTER_PASSWORD") or os.environ.get("ADMIN_PASSWORD", ""))
    if not expected:
        _die(
            "MASTER_PASSWORD is not set in .env. Run `./unifyroute setup` first "
            "or set MASTER_PASSWORD manually."
        )
    entered = getpass.getpass("  [PASSWORD] Enter master password: ")
    if entered != expected:
        _die("Incorrect master password.")
    return True


def _uv_run(args: list[str], **kwargs):
    """Run a command via uv in the project root."""
    uv = _find_uv()
    return subprocess.run(uv + ["run"] + args, cwd=str(SCRIPT_DIR), **kwargs)


# ── Commands ───────────────────────────────────────────────────────────────────

def cmd_setup(sub: list[str]):
    """Delegate to the Python setup script."""
    setup_script = SCRIPT_DIR / "scripts" / "setup.py"
    if not setup_script.exists():
        _die(f"Setup script not found at {setup_script}")
    sub_cmd = sub[0] if sub else "install"
    result = subprocess.run(
        [sys.executable, str(setup_script), sub_cmd],
        cwd=str(SCRIPT_DIR)
    )
    sys.exit(result.returncode)


def cmd_wizard():
    """Run the interactive provider/routing/brain setup wizard."""
    wizard_script = SCRIPT_DIR / "scripts" / "wizard.py"
    if not wizard_script.exists():
        _die(f"Wizard script not found at {wizard_script}")
    result = subprocess.run(
        [sys.executable, str(wizard_script)],
        cwd=str(SCRIPT_DIR)
    )
    sys.exit(result.returncode)


def cmd_start():
    """Start the UnifyRoute unified launcher."""
    import shutil
    import time
    print("🚀  Starting UnifyRoute...")

    # ── 1. Validate .env ──────────────────────────────────────────────
    env_file = SCRIPT_DIR / ".env"
    if not env_file.exists():
        _die(f".env file not found at {env_file}. Run './unifyroute setup' first.")

    _load_env()

    port = os.environ.get("PORT", "6565")
    host = os.environ.get("HOST", "0.0.0.0")

    # ── 2. Stop any existing processes on the port ────────────────────
    _info("Stopping any existing UnifyRoute processes...")
    _stop_server()
    time.sleep(0.5)

    # ── 3. Ensure Docker daemon + Redis are running ─────────────────────
    docker = shutil.which("docker")
    if docker:
        # Check if Docker daemon is running
        daemon_check = subprocess.run(
            [docker, "info"],
            capture_output=True, text=True,
        )
        if daemon_check.returncode != 0:
            _info("Docker daemon is not running. Starting Docker...")
            if sys.platform != "win32":
                start_result = subprocess.run(
                    ["sudo", "systemctl", "start", "docker"],
                    capture_output=True, text=True,
                )
                if start_result.returncode == 0:
                    _ok("Docker daemon started.")
                    time.sleep(2)  # Wait for daemon to be ready
                else:
                    print(f"  ⚠️  Could not start Docker daemon: {start_result.stderr.strip()}")
                    print("      Start Docker manually: sudo systemctl start docker")
            else:
                print("  ⚠️  Docker daemon is not running. Please start Docker Desktop.")

        _info("Ensuring Redis is running...")
        result = subprocess.run(
            [docker, "compose", "up", "-d", "redis"],
            cwd=str(SCRIPT_DIR),
            capture_output=True, text=True,
        )
        if result.returncode == 0:
            _ok("Redis is running.")
        else:
            print(f"  ⚠️  Could not start Redis: {result.stderr.strip()}")
            print("      Quota tracking and failover will be limited.")
    else:
        print("  ⚠️  Docker not found — Redis must be started manually.")
        print("      Run: docker compose up -d redis")

    # ── 4. Verify virtual environment exists ──────────────────────────
    venv_dir = SCRIPT_DIR / ".venv"
    if not venv_dir.exists():
        _die("Virtual environment not found. Run './unifyroute setup' first.")

    # ── 4. Auto-build GUI if dist/ is missing ─────────────────────────
    gui_dist = SCRIPT_DIR / "gui" / "dist"
    if not gui_dist.exists():
        _info("GUI build not found. Building automatically...")
        npm = shutil.which("npm")
        if not npm:
            _die("'npm' not found. Please install Node.js or run './unifyroute setup'.")
        gui_dir = SCRIPT_DIR / "gui"
        node_modules = gui_dir / "node_modules"
        if not node_modules.exists():
            _info("Installing frontend dependencies...")
            result = subprocess.run([npm, "install"], cwd=str(gui_dir))
            if result.returncode != 0:
                _die("npm install failed. Check the error above.")
        _info("Building frontend...")
        result = subprocess.run([npm, "run", "build"], cwd=str(gui_dir))
        if result.returncode != 0:
            _die("Frontend build failed. Check the error above.")
        _ok("Frontend built successfully.")

    # ── 5. Ensure log dir exists ──────────────────────────────────────
    log_dir = SCRIPT_DIR / "logs"
    log_dir.mkdir(exist_ok=True)
    log_file = log_dir / "app.log"

    print(f"ℹ️   Launcher starting on {host}:{port}")
    print(f"ℹ️   Logs → {log_dir}")

    # ── 6. Launch the server ──────────────────────────────────────────
    uv = _find_uv()
    if uv:
        cmd = uv + [
            "run", "--package", "launcher", "python", "-m", "uvicorn",
            "--app-dir", "launcher/src",
            "launcher.main:app", "--port", port, "--host", host
        ]
    else:
        if sys.platform == "win32":
            python = SCRIPT_DIR / ".venv" / "Scripts" / "python.exe"
        else:
            python = SCRIPT_DIR / ".venv" / "bin" / "python"

        if not python.exists():
            _die("Python not found in .venv. Run './unifyroute setup' first.")

        cmd = [
            str(python), "-m", "uvicorn",
            "--app-dir", "launcher/src",
            "launcher.main:app", "--port", port, "--host", host
        ]

    with open(log_file, "a") as lf:
        proc = subprocess.Popen(
            cmd,
            cwd=str(SCRIPT_DIR),
            stdout=lf,
            stderr=subprocess.STDOUT,
            env=os.environ.copy(),
        )

    # ── 7. Health check — wait for server to respond ──────────────────
    _info("Waiting for server to start...")
    health_url = f"http://localhost:{port}/api/health"
    max_wait = 15  # seconds
    started = False
    for i in range(max_wait * 2):
        time.sleep(0.5)
        # Check the process is still alive
        if proc.poll() is not None:
            # Process exited — read last few lines of log for context
            print()
            _die(
                f"Server process exited with code {proc.returncode}.\n"
                f"         Check {log_file} for details."
            )
        try:
            import urllib.request
            resp = urllib.request.urlopen(health_url, timeout=2)
            if resp.status == 200:
                started = True
                break
        except Exception:
            pass

    if started:
        _ok(f"UnifyRoute is running (PID {proc.pid}).")
        _info(f"Open: http://localhost:{port}")
        _info(f"Logs: {log_dir}/app.log  (access: {log_dir}/access.log)")
    else:
        print()
        _die(
            f"Server did not respond within {max_wait}s.\n"
            f"         Check {log_file} for errors."
        )


def _stop_server():
    """Kill any running UnifyRoute server process (by name and by port)."""
    _load_env()
    port = os.environ.get("PORT", "6565")

    if sys.platform == "win32":
        subprocess.run(["taskkill", "/IM", "python.exe", "/F"], capture_output=True)
    else:
        # Kill by process pattern
        subprocess.run(["pkill", "-f", "launcher.main:app"], capture_output=True)
        # Also kill whatever is holding the configured port — catches stale zombies
        # from previous starts that used a different command pattern.
        try:
            result = subprocess.run(
                ["lsof", "-ti", f":{port}"],
                capture_output=True, text=True
            )
            pids = result.stdout.strip().split()
            for pid in pids:
                if pid.isdigit():
                    subprocess.run(["kill", pid], capture_output=True)
        except Exception:
            pass  # lsof not available, ignore

    # Stop systemd service if active (Linux)
    if sys.platform != "win32":
        result = subprocess.run(
            ["systemctl", "is-active", "--quiet", "unifyroute.service"],
            capture_output=True
        )
        if result.returncode == 0:
            subprocess.run(["sudo", "systemctl", "stop", "unifyroute.service"])
            _ok("Systemd service stopped.")


def cmd_stop():
    """Stop the application."""
    print("🛑  Stopping UnifyRoute...")
    _stop_server()
    _ok("UnifyRoute stopped.")


def cmd_restart():
    print("🔄  Restarting UnifyRoute...")
    _stop_server()
    import time
    time.sleep(1)
    cmd_start()


def cmd_cleanstart():
    """
    Stop any running server, clear logs, then start fresh.
    Does NOT wipe the database or config — just kills stale processes and rotates logs.
    """
    print("🧹  Clean start — stopping everything...")
    _stop_server()

    import time
    time.sleep(1)

    # Rotate log file so new run starts clean
    log_file = SCRIPT_DIR / "logs" / "app.log"
    if log_file.exists():
        import datetime
        ts = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
        archived = log_file.with_name(f"api.{ts}.log")
        log_file.rename(archived)
        _info(f"Archived previous log → {archived.name}")

    print("🚀  Starting fresh...")
    cmd_start()


def cmd_get_token(sub: list[str]):
    """List gateway tokens. Requires master password."""
    print("")
    api_base = os.environ.get("API_BASE_URL", f"http://localhost:{os.environ.get('PORT', '6565')}")
    print(f"  API_BASE_URL: {api_base}")
    print("  " + "─" * 50)
    _verify_master_password()

    token_type = sub[0] if sub else None
    if token_type and token_type not in ("all", "admin", "api"):
        _die(f"Unknown token type: '{token_type}'. Use: all, admin, api")

    args = ["--package", "shared", "python", "scripts/list-keys.py"]
    if token_type and token_type != "all":
        args += ["--type", token_type]
    _uv_run(args)


def cmd_create_token(sub: list[str]):
    """Create a gateway token. Requires master password."""
    if not sub:
        _die("Usage: unifyroute create token [admin|api]")
    token_type = sub[0]
    if token_type not in ("admin", "api"):
        _die(f"Unknown token type: '{token_type}'. Use: admin or api")

    _verify_master_password()

    import datetime
    label = f"{token_type.capitalize()} Token {int(datetime.datetime.now().timestamp())}"
    _uv_run([
        "--package", "shared", "python", "scripts/create-key.py",
        label, "--type", token_type
    ])


def cmd_update_token(sub: list[str]):
    """Update a token label. Requires master password."""
    if len(sub) < 2:
        _die("Usage: unifyroute update token <id> <new_label>")
    key_id, new_label = sub[0], sub[1]
    _verify_master_password()
    _uv_run(["--package", "shared", "python", "scripts/update-key.py", key_id, new_label])

def cmd_import_keys(sub: list[str]):
    """Bulk import API keys. Requires master password."""
    if not sub:
        _die("Usage: unifyroute import-keys <file.json>")
    _verify_master_password()
    _uv_run(["--package", "shared", "python", "scripts/import-keys.py", sub[0]])



# ── Usage ──────────────────────────────────────────────────────────────────────

USAGE = """\
Usage: unifyroute [command]

Commands:
  setup [install|refresh|uninstall]   Manage the UnifyRoute installation
  wizard                              Interactive setup wizard (providers, routing, brain)
  start                               Start the application
  stop                                Stop the application
  restart                             Restart the application
  clean-start                         Stop everything, archive logs, start fresh
  get token [all|admin|api]           List API tokens (requires master password)
  create token [admin|api]            Create a new API token (requires master password)
  update token <id> <label>           Update a token's label (requires master password)
  import-keys <file>                  Bulk import provider API keys from a JSON/YAML file
  help                                Show this help message

Examples:
  ./unifyroute setup                  First-time interactive setup
  ./unifyroute wizard                 Run the provider/routing/brain wizard post-setup
  ./unifyroute setup refresh          Re-sync deps and rebuild GUI
  ./unifyroute setup uninstall        Clean up everything
  ./unifyroute start                  Start the app
  ./unifyroute clean-start            Stop stale processes, archive logs, start fresh
  ./unifyroute get token              List all tokens
  ./unifyroute create token admin     Create an admin token
"""


# ── Entry point ────────────────────────────────────────────────────────────────

def main():
    _load_env()

    args = sys.argv[1:]
    if not args or args[0] in ("help", "--help", "-h"):
        print(USAGE)
        sys.exit(0)

    cmd = args[0]
    rest = args[1:]

    if cmd == "setup":
        cmd_setup(rest)

    elif cmd == "wizard":
        cmd_wizard()

    elif cmd == "start":
        cmd_start()

    elif cmd == "stop":
        cmd_stop()

    elif cmd == "restart":
        cmd_restart()

    elif cmd in ("clean-start", "cleanstart"):
        cmd_cleanstart()

    elif cmd == "get":
        if rest and rest[0] == "token":
            cmd_get_token(rest[1:])
        else:
            _die(f"Unknown 'get' subcommand: {rest[0] if rest else '(none)'}. Try: unifyroute get token")

    elif cmd == "create":
        if rest and rest[0] == "token":
            cmd_create_token(rest[1:])
        else:
            _die(f"Unknown 'create' subcommand. Try: unifyroute create token [admin|api]")

    elif cmd == "update":
        if rest and rest[0] == "token":
            cmd_update_token(rest[1:])
        else:
            _die(f"Unknown 'update' subcommand. Try: unifyroute update token <id> <label>")

    elif cmd == "import-keys":
        cmd_import_keys(rest)

    else:
        _die(f"Unknown command: '{cmd}'\n\nRun: ./unifyroute help")


if __name__ == "__main__":
    main()
